OPENAI_API_TYPE=[YOURS]
OPENAI_API_VERSION=[YOURS]
OPENAI_API_BASE=[YOURS]
OPENAI_API_KEY=[YOURS]

SUPABASE_URL=[YOURS]
SUPABASE_JWT_SECRET=[YOURS]
SUPABASE_SERVICE_KEY=[YOURS]

MONGO_URL=[YOURS]
MONGO_DB_NAME=[YOURS]

POSTGRES_URL=[YOURS]

SMTP_HOST=[YOURS]
SMTP_PORT=[YOURS]
SMTP_USER=[YOURS]
SMTP_PASSWORD=[YOURS]
SMTP_FROM=[YOURS]
SMTP_SENDER_NAME=[YOURS]

LIGHTRAG_WORKING_DIR=./temp/lightrag

# Secret used to sign session cookies. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=[YOURS]
# Comma-separated list of allowed CORS origins (the frontend URL(s)).
ALLOWED_ORIGINS=http://localhost:3000

# Optional: model overrides (defaults: gpt-4o / gpt-4o-mini)
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_MINI=gpt-4o-mini

# Optional: paper search
# S2_API_KEY=[YOURS]
# OPENALEX_EMAIL=[YOURS]
# OPENALEX_API_KEY=[YOURS]

# Optional: reranker (RERANKER_TYPE=cohere|xinference)
# RERANKER_TYPE=[YOURS]
# COHERE_API_URL=[YOURS]
# COHERE_API_KEY=[YOURS]

# Set to true to enable user-study interaction logging
USER_STUDY_MODE=false